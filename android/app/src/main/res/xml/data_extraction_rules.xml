<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    Credential data is excluded from both cloud backup and device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude credential data from cloud backup -->
        <exclude domain="file" path="wifisync.db.enc" />
        <exclude domain="file" path="collections.json" />
        <exclude domain="file" path="profiles.json" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude credential data from device transfer -->
        <exclude domain="file" path="wifisync.db.enc" />
        <exclude domain="file" path="collections.json" />
        <exclude domain="file" path="profiles.json" />
    </device-transfer>
</data-extraction-rules>
