#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export CARGO_HOME = $(CURDIR)/debian/.cargo

%:
	dh $@

override_dh_auto_build:
	@if [ -z "$$SKIP_CARGO_BUILD" ]; then cargo build --release --locked; else echo "Using prebuilt binary"; fi

override_dh_auto_install:
	# Install binary
	install -Dm755 target/release/wifisync debian/wifisync/usr/bin/wifisync

	# Install systemd user service
	install -Dm644 packaging/systemd/wifisync-agent.service \
		debian/wifisync/usr/lib/systemd/user/wifisync-agent.service

override_dh_auto_test:
	@if [ -z "$$SKIP_CARGO_BUILD" ]; then cargo test --release --locked; else echo "Skipping tests for prebuilt binary"; fi

override_dh_auto_clean:
	@if [ -z "$$SKIP_CARGO_BUILD" ]; then cargo clean || true; fi
	rm -rf $(CARGO_HOME)

# Skip dh_installsystemd - user service is installed manually above
override_dh_installsystemd:
